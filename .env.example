# Conexión al servicio del biométrico
NEXT_PUBLIC_BIOMETRICO_HOST=192.168.2.xxx
NEXT_PUBLIC_BIOMETRICO_PORT=8899

# DEPLOY ENV prod | dev | test
NEXT_PUBLIC_DEPLOY_ENV=prod
